{
  "name": "watchcircle",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "common",
    "services/infra",
    "services/app-api",
    "services/app-ws",
    "apps/app",
    "apps/web"
  ],
  "scripts": {
    "preflight:dev": "bash scripts/preflight-dev.sh",
    "bootstrap:dev": "bash scripts/bootstrap-account.sh --env dev --region us-east-2 --tf-state-bucket watchcircle-dev-tf-state",
    "bootstrap:prod": "bash scripts/bootstrap-account.sh --env prod --region us-east-2 --tf-state-bucket watchcircle-prod-tf-state",
    "tf:init:dev": "terraform -chdir=terraform/dev init",
    "tf:plan:dev": "terraform -chdir=terraform/dev plan",
    "tf:apply:dev": "terraform -chdir=terraform/dev apply",
    "tf:init:prod": "terraform -chdir=terraform/prod init",
    "tf:plan:prod": "terraform -chdir=terraform/prod plan",
    "tf:apply:prod": "terraform -chdir=terraform/prod apply",
    "compose:deploy:dev": "serverless deploy --stage dev",
    "compose:deploy:prod": "serverless deploy --stage prod",
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:prod": "serverless deploy --stage prod",
    "bootstrap:account": "bash scripts/bootstrap-account.sh",
    "smoke:auth-chat": "bash scripts/smoke-auth-chat.sh",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:all": "npm run lint && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^8.57.1",
    "prettier": "^3.5.3",
    "serverless": "^3.40.0",
    "serverless-esbuild": "^1.55.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
